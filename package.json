{
  "name": "prayerboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^24",
      "onFail": "warn"
    },
    "packageManager": {
      "name": "pnpm",
      "version": "^11",
      "onFail": "warn"
    }
  },
  "scripts": {
    "prepare": "lefthook install",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "check": "biome check && tsc -b --noEmit",
    "fix": "biome check --write",
    "test": "vitest run"
  },
  "dependencies": {
    "solid-js": "^1.9.12"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@types/node": "^24.12.3",
    "browserslist": "^4.28.2",
    "lefthook": "^2.1.9",
    "lightningcss": "^1.32.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.9"
  }
}
